{
  "name": "career-timeline",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/features/career-timeline/src",
  "prefix": "app",
  "projectType": "library",
  "tags": ["type:feature", "scope:portfolio"],
  "targets": {
    "build": {
      "executor": "@nx/angular:ng-packagr-lite",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "options": {
        "project": "libs/features/career-timeline/ng-package.json",
        "tsConfig": "libs/features/career-timeline/tsconfig.lib.json"
      },
      "configurations": {
        "production": {
          "tsConfig": "libs/features/career-timeline/tsconfig.lib.prod.json"
        },
        "development": {}
      },
      "defaultConfiguration": "production"
    },
    "test": {
      "executor": "@nx/angular:unit-test",
      "options": {}
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "tsc --noEmit -p libs/features/career-timeline/tsconfig.lib.json",
          "tsc --noEmit -p libs/features/career-timeline/tsconfig.spec.json"
        ],
        "cwd": "{workspaceRoot}",
        "parallel": false
      },
      "cache": true,
      "inputs": ["default", "^default", "{projectRoot}/tsconfig*.json"]
    }
  }
}
